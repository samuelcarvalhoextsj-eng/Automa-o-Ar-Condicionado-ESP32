// ==========================================
// 4. FUNÇÃO QUE RECEBE COMANDOS DO MQTT
// ==========================================
void callbackMQTT(char* topic, byte* payload, unsigned int length) {
  String mensagem = "";
  for (int i = 0; i < length; i++) {
    mensagem += (char)payload[i];
  }
  
  Serial.print("Comando recebido [");
  Serial.print(topic);
  Serial.print("]: ");
  Serial.println(mensagem);

  // A MÁGICA: O C++ agora calcula sozinho o tamanho do array com o "sizeof"
  if (mensagem == "DESLIGAR") {
    Serial.println(">>> Enviando IR: DESLIGAR...");
    int tamanho = sizeof(rawDesligar) / sizeof(rawDesligar[0]);
    irsend.sendRaw(rawDesligar, tamanho, 38); 
  } 
  else if (mensagem == "LIGAR_18") {
    Serial.println(">>> Enviando IR: LIGAR EM 18ºC (TURBO)...");
    int tamanho = sizeof(raw18) / sizeof(raw18[0]);
    irsend.sendRaw(raw18, tamanho, 38);
  }
  else if (mensagem == "LIGAR_20") {
    Serial.println(">>> Enviando IR: LIGAR EM 20ºC...");
    int tamanho = sizeof(raw20) / sizeof(raw20[0]);
    irsend.sendRaw(raw20, tamanho, 38);
  }
  else if (mensagem == "LIGAR_22") {
    Serial.println(">>> Enviando IR: LIGAR EM 22ºC (CONFORTO)...");
    int tamanho = sizeof(raw22) / sizeof(raw22[0]);
    irsend.sendRaw(raw22, tamanho, 38);
  }
  else if (mensagem == "LIGAR_24") {
    Serial.println(">>> Enviando IR: LIGAR EM 24ºC (ECONÔMICO)...");
    int tamanho = sizeof(raw24) / sizeof(raw24[0]);
    irsend.sendRaw(raw24, tamanho, 38);
  }
}

// ==========================================
// 5. FUNÇÃO PARA CONECTAR NO WIFI E MQTT
// ==========================================
void reconectarMQTT() {
  while (!client.connected()) {
    Serial.print("Tentando conectar ao broker MQTT...");
    String clientId = "ESP32Sala-" + String(WiFi.macAddress()); // Usa o MAC para ser 100% único
    clientId += String(random(0xffff), HEX);
    
    if (client.connect(clientId.c_str())) {
      Serial.println("Conectado!");
      client.subscribe(topico_comando_ar);
    } else {
      Serial.print("Falha, rc=");
      Serial.print(client.state());
      Serial.println(" Tentando novamente em 5 segundos...");
      delay(5000);
    }
  }
}

// ==========================================
// 6. SETUP 
// ==========================================
void setup() {
  Serial.begin(115200);
  
  pinMode(PIR_PIN, INPUT);
  irsend.begin();
  dht.begin();

  Serial.println();
  Serial.print("Conectando ao WiFi ");
  Serial.println(ssid);
  WiFi.begin(ssid, password);
  
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nWiFi conectado! IP: ");
  Serial.println(WiFi.localIP());

  // No final do Setup():
// Força o ESP32 a entender que isso é um IP numérico puro (bypassa o DNS)
  client.setServer(mqtt_server, 1883);
  client.setCallback(callbackMQTT);
}

// ==========================================
// 7. LOOP 
// ==========================================
void loop() {
  if (!client.connected()) {
    reconectarMQTT();
  }
  client.loop(); 

  unsigned long tempoAtual = millis();

  // ----- LEITURA DO DHT11 (A CADA 5 SEGUNDOS) -----
  if (tempoAtual - tempoAnteriorDHT >= 5000) {
    tempoAnteriorDHT = tempoAtual;
    
    float temp = dht.readTemperature();
    float umid = dht.readHumidity();

    if (!isnan(temp) && !isnan(umid)) {
      client.publish(topico_temp, String(temp).c_str());
      client.publish(topico_umidade, String(umid).c_str());
    }
  }

  // ----- LEITURA DO PIR (EM TEMPO REAL) -----
  int estadoPirAtual = digitalRead(PIR_PIN);
  if (estadoPirAtual != estadoPirAnterior) {
    if (estadoPirAtual == HIGH) {
      Serial.println("Movimento detectado!");
      client.publish(topico_presenca, "MOVIMENTO");
    } else {
      Serial.println("Sala vazia...");
      client.publish(topico_presenca, "VAZIO");
    }
    estadoPirAnterior = estadoPirAtual;
  }
}